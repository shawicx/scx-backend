# ============================================================
# SCX Backend 环境变量配置模板
# ============================================================
# 用法：复制本文件为 .env，填入你的真实配置
#   cp .env.example .env
#
# 加载机制（spring-dotenv，四种启动方式完全一致）：
#   - IDEA 运行/调试   → 自动读 .env
#   - ./gradlew bootRun → 自动读 .env
#   - java -jar        → 自动读 .env（同目录）
#   - Docker / K8s     → 用 -e / Secret 注入（生产不用 .env 文件）
#
# 优先级：真实 OS 环境变量 > .env 文件 > application.yml 默认值
# ============================================================

# 应用配置
NODE_ENV=development
PORT=3000
SPRING_PROFILES_ACTIVE=dev

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=scx
DB_PASSWORD=your_secure_password_here
DB_DATABASE=scx-backend

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6388
REDIS_PASSWORD=

# JWT 配置（HMAC-SHA256 令牌密钥，生产环境必须替换为强随机值）
JWT_SECRET=please_change_to_a_strong_random_secret

# ---- 邮件配置（QQ 邮箱示例）----
# QQ 邮箱用 465 + SSL：MAIL_SSL=true, MAIL_STARTTLS=false
# Gmail 等用 587 + STARTTLS：MAIL_SSL=false, MAIL_STARTTLS=true
MAIL_ENABLED=true
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SSL=true
MAIL_STARTTLS=false
MAIL_USER=your_qq@qq.com
MAIL_PASSWORD=your_smtp_auth_code
MAIL_TIMEOUT_MS=30000
# QQ 邮箱授权码获取：设置 → 账户 → POP3/SMTP 服务 → 开启 → 生成授权码（非登录密码）

# Swagger 文档配置
SWAGGER_TITLE=SCX Backend API
SWAGGER_DESCRIPTION=SCX Backend API Documentation
SWAGGER_VERSION=1.0

# 超级管理员初始密码（首次启动 SeedService 创建超管用户用）
ADMIN_INITIAL_PASSWORD=changeme123
