# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=scx
DB_PASSWORD=scx_password
DB_DATABASE=scx-backend

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6388
REDIS_PASSWORD=

# JWT 配置（HMAC 令牌密钥）
JWT_SECRET=your_jwt_secret_here

# 邮件配置
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@example.com

# Swagger 文档配置
SWAGGER_TITLE=SCX Backend API
SWAGGER_DESCRIPTION=SCX Backend API Documentation
SWAGGER_VERSION=1.0

# 日志配置
LOG_DIR=logs

# 超级管理员初始密码
ADMIN_INITIAL_PASSWORD=changeme123
