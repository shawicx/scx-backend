<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- 日志目录：默认 /tmp/scx-backend-logs（容器内对所有用户可写，避免 Paketo 镜像
       工作目录 /workspace 对非 root 用户不可写导致 RollingFileAppender 初始化崩溃）。
       本地开发如需写到项目根的 logs 目录，设置环境变量 LOG_DIR=logs 即可覆盖。 -->
  <property name="LOG_DIR" value="${LOG_DIR:-/tmp/scx-backend-logs}"/>
  <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

  <!-- 控制台输出 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- 错误日志：按日轮转 -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/error/error.log</file>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>ERROR</level>
    </filter>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/error/error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>20MB</maxFileSize>
      <maxHistory>14</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- 综合日志：按日轮转 -->
  <appender name="COMBINED_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/combined/combined.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/combined/combined-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>20MB</maxFileSize>
      <maxHistory>14</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- 访问日志：AccessLogInterceptor 的 logger 名 ACCESS 单独输出 -->
  <appender name="ACCESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/access/access.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/access/access-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>20MB</maxFileSize>
      <maxHistory>14</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- 邮件模块独立日志 -->
  <appender name="MAIL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/mail/mail.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/mail/mail-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>20MB</maxFileSize>
      <maxHistory>14</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- dev 环境 -->
  <springProfile name="dev">
    <!-- 访问日志单独输出（additivity=false 不重复到 root） -->
    <logger name="ACCESS" level="INFO" additivity="false">
      <appender-ref ref="ACCESS_FILE"/>
      <appender-ref ref="CONSOLE"/>
    </logger>
    <!-- 邮件模块日志 -->
    <logger name="com.scx.backend.modules.mail" level="DEBUG" additivity="true">
      <appender-ref ref="MAIL_FILE"/>
    </logger>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="ERROR_FILE"/>
      <appender-ref ref="COMBINED_FILE"/>
    </root>
    <logger name="com.scx.backend" level="DEBUG"/>
  </springProfile>

  <!-- prod 环境 -->
  <springProfile name="prod">
    <logger name="ACCESS" level="INFO" additivity="false">
      <appender-ref ref="ACCESS_FILE"/>
      <!-- prod 也输出到控制台，便于 docker logs 查看 -->
      <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.scx.backend.modules.mail" level="INFO" additivity="true">
      <appender-ref ref="MAIL_FILE"/>
    </logger>
    <root level="INFO">
      <!-- CONSOLE 必加：容器化部署通过 docker logs 查看应用日志 -->
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="ERROR_FILE"/>
      <appender-ref ref="COMBINED_FILE"/>
    </root>
  </springProfile>
</configuration>
